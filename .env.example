# 📁 .env.example
# 🎯 Plantilla de variables de entorno globales — copiar a .env y completar.
# 📦 Capa: Configuración / Raíz

# === SafeCampus PUCP — Variables de entorno globales ===
# Copiar a .env y completar valores

# Database
# Supabase (principal): usar pooler y SSL obligatorio
# Si el password contiene '#', reemplazar por '%23'
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?ssl=require

# API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Supabase
SUPABASE_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ACCESS_TOKEN=
