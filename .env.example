# SafeCampus PUCP - root environment template
#
# Copy this file to .env at the repository root.
# Do not commit real .env files or credentials.

# ---------------------------------------------------------------------------
# Shared local endpoints
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ---------------------------------------------------------------------------
# Supabase/Postgres
# ---------------------------------------------------------------------------
# Use the Supabase pooler DSN with SQLAlchemy asyncpg and SSL.
# If the password contains '#', encode it as '%23'.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?ssl=require

# Required by pnpm gen:types. If omitted, it can be inferred from
# NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_PROJECT_ID=PROJECT_REF
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co

# Public anon key. This is safe for frontend usage, but still keep the real
# value in uncommitted env files.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional for non-interactive Supabase CLI usage, for example CI.
SUPABASE_ACCESS_TOKEN=

# Schemas included by pnpm gen:types. Keep aligned with backend ORM coverage.
SUPABASE_SCHEMAS=public,sc_users,sc_omnicanal,sc_incidentes,sc_clasificacion,sc_notificaciones,sc_dashboard,sc_lost_found,sc_acompanamiento,sc_auditoria
