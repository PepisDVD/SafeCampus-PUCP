# SafeCampus Backend - environment template
#
# Copy this file to apps/backend/.env.
# Do not commit real .env files or credentials.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PROJECT_NAME=SafeCampus PUCP
VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Use the Supabase pooler DSN with SQLAlchemy asyncpg and SSL.
# If the password contains '#', encode it as '%23'.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# Auth / session cookies
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE-ME-GENERATE-A-LONG-RANDOM-VALUE
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
SESSION_COOKIE_NAME=safecampus_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Local development URLs.
WEB_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Supabase Auth / user sync
# ---------------------------------------------------------------------------
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# service_role key — Supabase → Project Settings → API → service_role (secret).
# Necesaria para escribir en Supabase Storage. NUNCA exponerla en el frontend.
SUPABASE_SERVICE_KEY=
# Nombre del bucket público en Supabase Storage para evidencias de incidentes.
SUPABASE_STORAGE_BUCKET=evidencias
ALLOWED_INSTITUTIONAL_DOMAIN=pucp.edu.pe
DEFAULT_COMMUNITY_ROLE_ID=00000000-0000-0000-0000-000000000000

# Dev allowlist (excepción al dominio institucional).
# Correos puntuales (típicamente @gmail.com de devs) autorizados a iniciar sesión.
# Lista separada por comas. Dejar vacío en producción.
DEV_ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# OAuth provider used by Supabase Auth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# External integrations
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_MAPS_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
