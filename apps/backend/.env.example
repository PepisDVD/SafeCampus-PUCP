# 📁 apps/backend/.env.example
# 🎯 Plantilla de variables de entorno del backend — copiar a .env y completar.
# 📦 Capa: Configuración

# === SafeCampus Backend — Variables de entorno ===

# --- App ---
DEBUG=true
SECRET_KEY=CHANGE-ME-IN-PRODUCTION
SESSION_COOKIE_NAME=safecampus_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=
WEB_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000

# --- Database ---
# Supabase (principal): usar pooler y SSL obligatorio
# Si el password contiene '#', reemplazar por '%23'
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?ssl=require

# --- Supabase Auth / User Sync ---
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
ALLOWED_INSTITUTIONAL_DOMAIN=pucp.edu.pe
DEFAULT_COMMUNITY_ROLE_ID=00000000-0000-0000-0000-000000000000

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- WhatsApp Business API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- Gmail OAuth2 (autenticación institucional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
