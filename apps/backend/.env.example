# SafeCampus Backend - environment template
#
# Copy this file to apps/backend/.env.
# Do not commit real .env files or credentials.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PROJECT_NAME=SafeCampus PUCP
VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Use the Supabase pooler DSN with SQLAlchemy asyncpg and SSL.
# If the password contains '#', encode it as '%23'.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_ECHO=false

# ---------------------------------------------------------------------------
# Auth / session cookies
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE-ME-GENERATE-A-LONG-RANDOM-VALUE
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
SESSION_COOKIE_NAME=safecampus_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Local development URLs.
WEB_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Supabase Auth / user sync
# ---------------------------------------------------------------------------
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# service_role key — Supabase → Project Settings → API → service_role (secret).
# Necesaria para escribir en Supabase Storage. NUNCA exponerla en el frontend.
SUPABASE_SERVICE_KEY=
# Nombre del bucket público en Supabase Storage para evidencias de incidentes.
SUPABASE_STORAGE_BUCKET=evidencias
ALLOWED_INSTITUTIONAL_DOMAIN=pucp.edu.pe
DEFAULT_COMMUNITY_ROLE_ID=00000000-0000-0000-0000-000000000000

# Dev allowlist (excepción al dominio institucional).
# Correos puntuales (típicamente @gmail.com de devs) autorizados a iniciar sesión.
# Lista separada por comas. Dejar vacío en producción.
DEV_ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# OAuth provider used by Supabase Auth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# External integrations
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=15
LLM_MAX_ATTEMPTS=3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CHATBOT_ENABLED=true
CHATBOT_AUTO_CREATE_INCIDENTS=true
# UUID de un usuario técnico existente en sc_users.usuario para registrar
# incidentes creados automáticamente desde WhatsApp.
CHATBOT_SYSTEM_USER_ID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# WhatsApp messaging provider abstraction.
# Local/dev: evolution. Future Meta Cloud API: meta.
WHATSAPP_PROVIDER=evolution
# Optional local allowlist. If empty, all numbers are accepted.
# Use international format without '+', separated by commas.
WHATSAPP_ALLOWED_TEST_PHONES=
# Keep true in local chatbot tests to avoid processing WhatsApp group chats.
WHATSAPP_IGNORE_GROUP_MESSAGES=true

# EvolutionAPI local/dev. The Manager proxy runs on 8081; the API stays on 8080.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-local-evolution-api-key
EVOLUTION_INSTANCE_NAME=safecampus-dev
# Optional. If set, webhook requests must send x-safecampus-webhook-secret.
EVOLUTION_WEBHOOK_SECRET=

# Meta WhatsApp Cloud API placeholders. Leave empty until Meta approval.
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=

# ---------------------------------------------------------------------------
# Correo / Notificaciones (Resend)
# ---------------------------------------------------------------------------
# Habilita el envío real de correos. Pon true cuando tengas API key y remitente.
EMAIL_ENABLED=false
# API key de Resend (https://resend.com/api-keys).
RESEND_API_KEY=
# Remitente. Para pruebas sin dominio verificado usa el sandbox de Resend:
#   RESEND_FROM_EMAIL=onboarding@resend.dev
# (solo entrega al correo dueño de la cuenta de Resend). En producción usa un
# dominio verificado, p. ej. notificaciones@safecampus.pucp.edu.pe
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=SafeCampus PUCP
