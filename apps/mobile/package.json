{
  "name": "@safecampus/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:lan": "expo start --lan",
    "dev:lan:clear": "expo start --lan --clear",
    "dev:lan:auto": "node scripts/start-expo-with-lan-api.mjs --lan --clear",
    "dev:tunnel": "expo start --tunnel",
    "dev:tunnel:auto": "node scripts/start-expo-with-lan-api.mjs --tunnel --clear",
    "dev:localhost": "expo start --localhost",
    "start": "expo start",
    "build": "node -e \"console.log('Use EAS build for mobile artifacts')\"",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "@safecampus/data": "workspace:*",
    "@safecampus/shared-types": "workspace:*",
    "@safecampus/ui-native": "workspace:*",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@safecampus/config": "workspace:*",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "typescript": "~5.9.2",
    "vitest": "^2.1.8"
  }
}
