{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://safecampus-pucp-production.up.railway.app/api/v1",
        "EXPO_PUBLIC_ALLOW_DEMO": "false",
        "EXPO_PUBLIC_IDLE_MS": "1800000",
        "EXPO_PUBLIC_HTTP_TIMEOUT_MS": "15000",
        "EXPO_PUBLIC_HTTP_MAX_RETRIES": "3"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://safecampus-pucp-production.up.railway.app/api/v1",
        "EXPO_PUBLIC_ALLOW_DEMO": "false",
        "EXPO_PUBLIC_IDLE_MS": "1800000",
        "EXPO_PUBLIC_HTTP_TIMEOUT_MS": "15000",
        "EXPO_PUBLIC_HTTP_MAX_RETRIES": "3"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
