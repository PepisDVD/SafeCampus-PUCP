# SafeCampus Web - local environment template
#
# Copy this file to apps/web/.env.local.
# Do not commit real .env.local files or credentials.

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# Public URL used by browser/client code.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Server-only URL used by Next.js proxy, Server Components, and Server Actions.
# In local development it can match NEXT_PUBLIC_API_URL. In Docker/CI it can
# point to an internal backend hostname.
BACKEND_URL=http://localhost:8000/api/v1

# ---------------------------------------------------------------------------
# Public browser configuration
# ---------------------------------------------------------------------------
NEXT_PUBLIC_DOMAIN=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ---------------------------------------------------------------------------
# Supabase public values
# ---------------------------------------------------------------------------
# These are kept for shared typed clients and type generation compatibility.
# The web app must not start OAuth directly against Supabase; authentication is
# owned by the backend.
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ---------------------------------------------------------------------------
# Dev allowlist (excepción al dominio institucional)
# ---------------------------------------------------------------------------
# Correos puntuales (@gmail.com de devs) que pueden iniciar sesión.
# Debe coincidir con la lista del backend (DEV_ALLOWED_EMAILS).
# Lista separada por comas. Dejar vacío en builds productivos.
NEXT_PUBLIC_DEV_ALLOWED_EMAILS=
